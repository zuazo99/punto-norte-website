# Contentful CMS
# Obtén estos valores en: https://app.contentful.com → Space → Settings → API keys

# ID del espacio Contentful
CONTENTFUL_SPACE_ID=tu_space_id

# Token de acceso para producción (Content Delivery API)
CONTENTFUL_DELIVERY_TOKEN=tu_delivery_token

# Token de acceso para preview/desarrollo (Content Preview API)
CONTENTFUL_PREVIEW_TOKEN=tu_preview_token
